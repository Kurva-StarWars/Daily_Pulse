<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Daily Pulse</title>
    
    <!-- Настройки PWA для иконки на главном экране -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Daily Pulse">
    <link rel="apple-touch-icon" href="https://img.icons8.com/fluency/180/pulse.png">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg: #0d1117;
            --card: #161b22;
            --accent: #58a6ff;
            --text: #c9d1d9;
            --header: #010409;
            --success: #238636;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: -apple-system, system-ui, sans-serif;
            margin: 0; padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        /* Брендинг с пульсом */
        .logo-container {
            display: flex; flex-direction: column; align-items: center;
            line-height: 0.8; user-select: none; padding: 10px 0;
        }

        .logo-top, .logo-bottom {
            font-size: 1.1rem; font-weight: 900; letter-spacing: 4px; color: #fff;
        }

        .logo-bottom { color: var(--accent); }

        .pulse-svg { width: 90px; height: 22px; margin: 4px 0; }
        .pulse-svg path {
            stroke-dasharray: 100;
            animation: dash 3.5s linear infinite;
        }

        @keyframes dash {
            from { stroke-dashoffset: 200; }
            to { stroke-dashoffset: 0; }
        }

        header {
            background: var(--header);
            position: sticky; top: 0; z-index: 100;
            border-bottom: 1px solid #30363d; padding-bottom: 5px;
        }

        .header-top {
            display: flex; flex-direction: column; align-items: center;
            max-width: 1200px; margin: 0 auto; padding: 5px 15px;
        }

        .search-box {
            display: flex; background: #0d1117; border: 1px solid #30363d;
            border-radius: 8px; padding: 8px 12px; width: 90%; max-width: 500px;
            margin: 10px 0;
        }

        .search-box input {
            background: transparent; border: none; color: white; width: 100%; outline: none; font-size: 1rem;
        }

        .categories {
            display: flex; gap: 8px; overflow-x: auto;
            justify-content: flex-start; padding: 10px 15px;
            max-width: 1200px; margin: 0 auto;
        }

        @media (min-width: 768px) { .categories { justify-content: center; } }
        .categories::-webkit-scrollbar { display: none; }

        button {
            background: #21262d; color: #c9d1d9; border: 1px solid #30363d;
            padding: 8px 18px; border-radius: 20px; cursor: pointer;
            transition: 0.2s; font-size: 0.85rem; font-weight: 600;
            white-space: nowrap;
        }

        button.active { background: var(--accent); color: #0d1117; border-color: var(--accent); }

        main { max-width: 1200px; margin: 15px auto; padding: 0 15px; }

        #news-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .card {
            background: var(--card); border-radius: 16px;
            overflow: hidden; display: flex; flex-direction: column;
            border: 1px solid #30363d; transition: 0.3s;
        }

        .card:hover { border-color: var(--accent); transform: translateY(-3px); }

        .img-container { width: 100%; height: 160px; background: #21262d; position: relative; }
        .img-container img { width: 100%; height: 100%; object-fit: cover; }
        .img-fallback { 
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
            display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: #30363d;
        }

        .content { padding: 16px; flex-grow: 1; display: flex; flex-direction: column; }
        .date { font-size: 0.75rem; color: var(--accent); margin-bottom: 8px; font-weight: 800; text-transform: uppercase; }
        .title { font-size: 1.05rem; font-weight: 700; margin-bottom: 15px; color: #fff; line-height: 1.3; }
        
        .btn-read {
            margin-top: auto; width: 100%; background: var(--success); color: white;
            border: none; padding: 12px; border-radius: 10px;
            font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 1px;
        }

        /* Модальный ридер */
        #reader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--bg); z-index: 1000; display: none; flex-direction: column;
        }

        .reader-nav {
            padding: 12px 20px; background: var(--header);
            display: flex; justify-content: space-between; border-bottom: 1px solid #30363d;
            align-items: center;
        }

        .reader-content {
            flex-grow: 1; overflow-y: auto; padding: 25px 20px;
            max-width: 800px; margin: 0 auto; width: 100%;
        }

        .reader-content h1 { font-size: 1.6rem; color: #fff; line-height: 1.2; margin-bottom: 20px; }
        .article-text p { margin-bottom: 1.2rem; font-size: 1.15rem; line-height: 1.6; color: #e2e8f0; }

        .close-btn { cursor: pointer; font-size: 1.8rem; color: var(--accent); }

        .loading {
            display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;
        }

        .spin {
            width: 35px; height: 35px; border: 3px solid rgba(88, 166, 255, 0.1);
            border-left-color: var(--accent); border-radius: 50%;
            animation: spin 0.6s linear infinite; margin-bottom: 10px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>

<header>
    <div class="header-top">
        <div class="logo-container">
            <span class="logo-top">DAILY</span>
            <svg class="pulse-svg" viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 10 H30 L35 2 L45 18 L50 10 H100" fill="transparent" stroke="#58a6ff" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span class="logo-bottom">PULSE</span>
        </div>
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass" style="margin-right: 10px; color: #8b949e;"></i>
            <input type="text" id="searchInput" placeholder="Поиск новостей..." onkeyup="if(event.key==='Enter') searchNews()">
        </div>
    </div>
    <div class="categories">
        <button class="active" onclick="fetchNews('top', this)">Главное</button>
        <button onclick="fetchNews('technology', this)">Техно</button>
        <button onclick="fetchNews('games', this)">Игры 🎮</button>
        <button onclick="fetchNews('sports', this)">Спорт</button>
        <button onclick="fetchNews('business', this)">Бизнес</button>
    </div>
</header>

<main id="news-grid"></main>

<div id="reader">
    <div class="reader-nav">
        <span style="font-weight: bold; color: var(--accent); letter-spacing: 1px;">READER MODE</span>
        <span class="close-btn" onclick="closeReader()"><i class="fa-solid fa-circle-xmark"></i></span>
    </div>
    <div class="reader-content" id="reader-body"></div>
</div>

<script>
    const geminiKey = ""; // Ключ API будет подставлен средой выполнения

    // Функция загрузки новостей (через RSS Google News для стабильности)
    async function fetchNews(query, btn) {
        const grid = document.getElementById('news-grid');
        if(btn) {
            document.querySelectorAll('button').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        grid.innerHTML = '<div class="loading"><div class="spin"></div><p>Синхронизация пульса...</p></div>';

        let rssUrl = `https://news.google.com/rss/headlines/section/topic/${query.toUpperCase()}?hl=ru&gl=RU&ceid=RU:ru`;
        if(query === 'top') rssUrl = `https://news.google.com/rss?hl=ru&gl=RU&ceid=RU:ru`;
        if(query === 'games') rssUrl = `https://news.google.com/rss/search?q=игры+гейминг+консоли+релизы&hl=ru&gl=RU&ceid=RU:ru`;
        if(query.includes('http')) rssUrl = query; // Для поиска через URL

        // Используем RSS2JSON для обхода CORS
        const apiUrl = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}`;

        try {
            const res = await fetch(apiUrl);
            const data = await res.json();
            
            // СОРТИРОВКА: От новых к старым
            const sortedItems = data.items.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));

            grid.innerHTML = '';
            sortedItems.forEach(item => {
                const date = new Date(item.pubDate).toLocaleString('ru-RU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
                const cleanTitle = item.title.split(' - ')[0]; // Убираем название издания из заголовка
                
                // Пробуем найти картинку в описании
                const imgMatch = item.description.match(/src="([^"]+)"/);
                const imgSrc = imgMatch ? imgMatch[1] : '';

                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="img-container">
                        ${imgSrc ? `<img src="${imgSrc}" alt="news">` : '<div class="img-fallback"><i class="fa-solid fa-bolt"></i></div>'}
                    </div>
                    <div class="content">
                        <div class="date"><i class="fa-solid fa-clock"></i> ${date}</div>
                        <div class="title">${cleanTitle}</div>
                        <button class="btn-read" onclick="openArticle('${item.link}', '${cleanTitle.replace(/'/g, "\\'")}')">Прочитать</button>
                    </div>
                `;
                grid.appendChild(card);
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch(e) {
            grid.innerHTML = '<div class="loading"><p>Ошибка загрузки. Обновите страницу.</p></div>';
        }
    }

    // Поиск
    function searchNews() {
        const val = document.getElementById('searchInput').value;
        if(!val) return;
        const searchUrl = `https://news.google.com/rss/search?q=${encodeURIComponent(val)}&hl=ru&gl=RU&ceid=RU:ru`;
        fetchNews(searchUrl);
    }

    // Открытие статьи через Gemini
    async function openArticle(url, title) {
        const reader = document.getElementById('reader');
        const body = document.getElementById('reader-body');
        reader.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        body.innerHTML = '<div class="loading"><div class="spin"></div><p>ИИ копирует текст...</p></div>';

        try {
            // Оптимизированный промпт для мгновенного копирования
            const prompt = `SOURCE URL: ${url}. NEWS TITLE: ${title}. 
            TASK: Locate and copy the full original article text in Russian. 
            Do NOT summarize. Check that the content matches the title. 
            Format only with simple <p> paragraphs. Add relevant emojis. Fast output please.`;
            
            const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${geminiKey}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
            });

            const data = await response.json();
            const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "Текст не найден. Попробуйте открыть другую статью.";
            
            body.innerHTML = `
                <h1>${title}</h1>
                <div class="article-text">${text.split('\n').map(p => p.trim() ? `<p>${p}</p>` : '').join('')}</div>
            `;
        } catch (err) {
            body.innerHTML = `<h1>Ошибка</h1><p>Не удалось выгрузить данные. Вероятно, источник защищен. <br><br> <a href="${url}" target="_blank" style="color:var(--accent)">Открыть в браузере</a></p>`;
        }
    }

    // Закрытие ридера
    function closeReader() { 
        document.getElementById('reader').style.display = 'none'; 
        document.body.style.overflow = 'auto';
    }
    
    // Инициализация
    window.onload = () => fetchNews('top');
</script>

</body>
</html>
